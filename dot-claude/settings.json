{
  "theme": "dark-ansi",
  "model": "opusplan",
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(git add:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(gh auth status:*)",
      "Bash(pnpm:*)"
    ],
    "deny": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(git add -a:*)",
      "Bash(git add -A:*)",
      "Bash(git add -u:*)"
    ],
    "ask": [
      "Bash(gh pr create:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm exec:*)",
      "WebFetch(*)"
    ]
  },
  "sandbox": {
    "enabled": false
  },
  "enabledPlugins": {
    "feature-dev@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "security-guidance@claude-plugins-official": true,
    "figma@claude-plugins-official": false,
    "typescript-lsp@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "github@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  },
  "language": "Japanese",
  "plansDirectory": ".claude/plans",
  "spinnerTipsEnabled": false,
  "autoMemoryEnabled": false,
  "outputStyle": "Explanatory",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "msg=$(jq -r '.message // .title // \"Claude Code: Waiting for your response\"' 2>/dev/null || echo 'Claude Code: Waiting for your response'); tty_path=$(ps -C claude -o tty= 2>/dev/null | head -1 | tr -d ' '); [ -n \"$tty_path\" ] && printf '\\033]9;%s\\007\\a' \"$msg\" > \"/dev/$tty_path\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tty_path=$(ps -C claude -o tty= 2>/dev/null | head -1 | tr -d ' '); [ -n \"$tty_path\" ] && printf '\\033]9;Claude Code: Work completed\\007\\a' > \"/dev/$tty_path\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
